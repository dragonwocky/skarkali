---
import { getEntry } from "@/packages/keystatic/content";
import Layout from "@/packages/echeveria/Layout.astro";
import { posts } from "../schema/collections";
import { render, fromMarkdoc } from "@/packages/comark";

const data = await getEntry<typeof posts>("posts", "index"),
  { node } = await data.content();
---

<Layout>
  <main set:html={render(fromMarkdoc(node))} />
</Layout>
