---
import Layout from "../layout.astro";
import { fromMarkdoc, render } from "../packages/comark";
import { getEntry } from "../packages/keystatic/reader";
import { posts } from "../schema/collections";

const data = await getEntry<typeof posts>("posts", "index"),
  { node } = await data.content(),
  ast = fromMarkdoc(node),
  html = await render(ast);
---

<Layout>
  <Fragment set:html={html} />
</Layout>
